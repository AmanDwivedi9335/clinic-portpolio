# ICICI environment mode: UAT or PROD
ICICI_ENV_MODE=UAT

# UAT example host can differ from production host. Confirm with onboarding team.
ICICI_BASE_URL=https://pgpay.icicibank.com
ICICI_INITIATE_PATH=/pg/api/v2/initiateSale
ICICI_TXN_STATUS_PATH=/pg/api/v2/transactionStatus

ICICI_MERCHANT_ID=YOUR_MERCHANT_ID
ICICI_AGGREGATOR_ID=YOUR_AGGREGATOR_ID
ICICI_MERCHANT_KEY=YOUR_HASH_SECRET
ICICI_HASH_VERSION=v1

# Backend callback/advice endpoints
ICICI_RETURN_URL=https://your-domain.com/api/payments/icici/callback
ICICI_PAYMENT_ADVICE_URL=https://your-domain.com/api/payments/icici/advice

# Frontend status page
NEXT_PUBLIC_PAYMENT_STATUS_BASE_URL=https://your-domain.com/payment/status

# Networking and reconciliation controls
ICICI_TIMEOUT_MS=15000
ICICI_RECONCILE_MAX_ATTEMPTS=5
